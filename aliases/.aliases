#!/usr/bin/env sh

CURSOR_PATH="/usr/bin/cursor"

FEDORA_WORKSTATION_PATH="$HOME/fedora-workstation"
SCRIPTS_PATH="$FEDORA_WORKSTATION_PATH/scripts"
BACKUP_SCRIPTS_PATH="$SCRIPTS_PATH/backup"

# Copy to clipboard on Wayland.
alias cb="wl-copy"

# Update system packages, flatpaks, and snaps.
alias update="sudo dnf up -y && flatpak update -y && sudo snap refresh"

# Start a nested GNOME Shell instance for extension development
alias gsdw="dbus-run-session gnome-shell --devkit --wayland"

# Update versioned dconf config.
dconf_pull() {
  "$SCRIPTS_PATH/dconf/pull.sh"
}

# Commit and push changes to tracked dconf config.
dconf_push() {
  "$SCRIPTS_PATH/dconf/push.sh"
}

# Enables the cursor command to open files or directories through the terminal.
cursor() {
	"$CURSOR_PATH" --no-sandbox "$@"
}

# Start a systemd service.
start() {
  sudo systemctl start "$@"
}

# Stop a systemd service.
stop() {
  sudo systemctl stop "$@"
}

# Backup a project directory, excluding common package manager caches and dependencies, recursively.
backup_projects() {
	"$BACKUP_SCRIPTS_PATH/backup-projects.sh" "$@"
}

# Backup select directories and files from the home directory.
backup_home() {
	"$BACKUP_SCRIPTS_PATH/backup-home.sh"
}
